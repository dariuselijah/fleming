# =============================================================================
# FLEMING - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and update with your actual values
# =============================================================================

# =============================================================================
# SUPABASE CONFIGURATION (Required)
# =============================================================================
# Get these from your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Server admin client (comms webhooks, practice bootstrap). Prefer this name — see lib/supabase/admin.ts
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Legacy alias still read by some scripts / Edge proxies
SUPABASE_SERVICE_ROLE=your_supabase_service_role_key
#
# Postgres migrations (`scripts/run-migration.ts`) — use ONE of:
# - DATABASE_URL — copy "URI" from Supabase → Settings → Database (includes ?sslmode=require), OR
# - SUPABASE_DB_PASSWORD — the database user password (Settings → Database). NOT the anon/service_role API keys.
#   The service_role JWT is not a Postgres password; using it causes: SCRAM-SERVER-FINAL-MESSAGE: server signature is missing
# DATABASE_URL=postgresql://postgres.xxxx:YOUR_DB_PASSWORD@aws-0-....pooler.supabase.com:6543/postgres
# SUPABASE_DB_PASSWORD=

# =============================================================================
# AI MODEL API KEYS (Optional - Add the ones you want to use)
# =============================================================================
# OpenAI API Key - Required for GPT models
OPENAI_API_KEY=your_openai_api_key

# Azure Document Intelligence - Recommended for OCR across images/PDF/Office docs
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_DOCUMENT_INTELLIGENCE_API_KEY=your_azure_document_intelligence_api_key
AZURE_DOCUMENT_INTELLIGENCE_API_VERSION=2024-11-30

# Docling (default on; set ENABLE_DOCLING_UPLOAD_PARSER=false to disable)
# DOCLING_SERVICE_URL — optional. If unset, the app uses:
#   {NEXT_PUBLIC_SUPABASE_URL or SUPABASE_URL}/functions/v1/docling-parse
# Server must send Authorization: Bearer <SUPABASE_SERVICE_ROLE_KEY or SUPABASE_SERVICE_ROLE>.
# DOCLING_USE_SUPABASE_EDGE=false — force-disable Edge URL resolution (use DOCLING_SERVICE_URL or no Docling).
# Edge Function docling-parse proxies to Python; set secret DOC_RUNTIME_URL in Supabase (see services/docling-runtime).
ENABLE_DOCLING_UPLOAD_PARSER=true
DOCLING_USE_SUPABASE_EDGE=true
# DOCLING_SERVICE_URL=http://127.0.0.1:8088
DOCLING_TIMEOUT_MS=18000
DOCLING_MAX_FIGURES_PER_UNIT=4
# Chat waits up to this long for selected uploads to finish indexing before grounded retrieval.
UPLOAD_READY_GATE_MAX_WAIT_MS=45000
UPLOAD_READY_GATE_POLL_MS=1500

# Mistral AI API Key - Required for Mistral models
MISTRAL_API_KEY=your_mistral_api_key

# Google Generative AI API Key - Required for Gemini models
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key

# Perplexity API Key - Required for Perplexity models
PERPLEXITY_API_KEY=your_perplexity_api_key

# Anthropic API Key - Required for Claude models
ANTHROPIC_API_KEY=your_anthropic_api_key

# XAI API Key - Required for xAI models
XAI_API_KEY=your_xai_api_key

# OpenRouter API Key - Required for OpenRouter models
OPENROUTER_API_KEY=your_openrouter_api_key

# =============================================================================
# OLLAMA CONFIGURATION (Optional - for local AI models)
# =============================================================================
# Base URL for Ollama server (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Disable Ollama in development/production
# DISABLE_OLLAMA=true

# =============================================================================
# SECURITY & ENCRYPTION
# =============================================================================
# CSRF Protection Secret - Generate a secure random string
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=your_csrf_secret_key_32_bytes_hex

# Encryption Key for API keys - Generate a 32-byte base64 key
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=your_32_byte_base64_encryption_key

# =============================================================================
# REDIS / CACHE (Optional – enables multi-level retrieval caching)
# =============================================================================
# Upstash Redis REST credentials (serverless, Edge-compatible)
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# =============================================================================
# SEARCH & EXTERNAL SERVICES
# =============================================================================
# Exa API Key for web search functionality
EXA_API_KEY=your_exa_api_key

# Server-side feature flag for explicit Exa web search tool (set false to disable)
ENABLE_WEB_SEARCH_TOOL=true

# Server-side LangGraph orchestration flag for clinical harness routing
ENABLE_LANGGRAPH_HARNESS=true

# Server-side LangChain multi-agent supervisor (hybrid with harness fallback)
ENABLE_LANGCHAIN_SUPERVISOR=true

# Enables full cognitive orchestration metadata (runtime DAG, confidence loops, gatekeeper rationale)
ENABLE_COGNITIVE_ORCHESTRATION_FULL=true

# Enables connector registry tools (scholar gateway, biorxiv, npi, cms, chembl, etc.)
ENABLE_CONNECTOR_REGISTRY=true

# Enforces stricter citation marker hygiene in evidence mode
ENABLE_STRICT_CITATION_CONTRACT=true

# Domain-tuned retrieval embedding model (optional, defaults to OpenAI text-embedding-3-small)
# RETRIEVAL_EMBEDDING_MODEL=text-embedding-3-small
# RETRIEVAL_EMBEDDING_DIMENSION=1536
# RETRIEVAL_EMBEDDING_API_BASE=https://api.openai.com

# HyDE query optimizer (generates hypothetical answers for better embedding retrieval)
# ENABLE_HYDE_QUERY_OPTIMIZER=true

# Cross-encoder reranking for evidence results (ON by default, set false to disable)
# ENABLE_CROSS_ENCODER_RERANK=true

# NCBI/PubMed API key for higher rate limits on ingestion and delta sync
# NCBI_API_KEY=your_ncbi_api_key

# Cron job secret for delta sync endpoint authentication
# CRON_SECRET=your_cron_secret

# Adaptive RAG: iterative retrieval on low-confidence first pass
# ENABLE_ADAPTIVE_RAG=false

# Enables Cursor-style continuous activity timeline in chat UI
ENABLE_CHAT_ACTIVITY_TIMELINE_V2=true

# Client-side toggle for clickable chart drill-down sub-orchestration
NEXT_PUBLIC_ENABLE_CHART_DRILLDOWN_SUBLOOP=true

# Client-side guard for direct upload object size limit (MB).
# Set to your Supabase storage object cap to fail fast before XMLHttpRequest upload.
NEXT_PUBLIC_SUPABASE_STORAGE_OBJECT_LIMIT_MB=512

# YouTube Data API v3 key for conditional educational video search
YOUTUBE_API_KEY=your_youtube_data_api_key

# Server-side feature flag for the YouTube tool (set false to disable)
ENABLE_YOUTUBE_TOOL=true

# =============================================================================
# HEALTH CONNECTORS - WEARABLE PROVIDERS (Optional)
# =============================================================================
# Fitbit OAuth2
FITBIT_CLIENT_ID=your_fitbit_client_id
FITBIT_CLIENT_SECRET=your_fitbit_client_secret
FITBIT_REDIRECT_URI=https://your-domain.com/api/health-connectors/callback
FITBIT_AUTH_URL=https://www.fitbit.com/oauth2/authorize
FITBIT_TOKEN_URL=https://api.fitbit.com/oauth2/token

# Oura OAuth2
OURA_CLIENT_ID=your_oura_client_id
OURA_CLIENT_SECRET=your_oura_client_secret
OURA_REDIRECT_URI=https://your-domain.com/api/health-connectors/callback
OURA_AUTH_URL=https://cloud.ouraring.com/oauth/authorize
OURA_TOKEN_URL=https://api.ouraring.com/oauth/token

# WHOOP OAuth2
WHOOP_CLIENT_ID=your_whoop_client_id
WHOOP_CLIENT_SECRET=your_whoop_client_secret
WHOOP_REDIRECT_URI=https://your-domain.com/api/health-connectors/callback
WHOOP_AUTH_URL=https://api.prod.whoop.com/oauth/oauth2/auth
WHOOP_TOKEN_URL=https://api.prod.whoop.com/oauth/oauth2/token

# Withings OAuth2
WITHINGS_CLIENT_ID=your_withings_client_id
WITHINGS_CLIENT_SECRET=your_withings_client_secret
WITHINGS_REDIRECT_URI=https://your-domain.com/api/health-connectors/callback
WITHINGS_AUTH_URL=https://account.withings.com/oauth2_user/authorize2
WITHINGS_TOKEN_URL=https://wbsapi.withings.net/v2/oauth2

# Polar AccessLink OAuth2
POLAR_CLIENT_ID=your_polar_client_id
POLAR_CLIENT_SECRET=your_polar_client_secret
POLAR_REDIRECT_URI=https://your-domain.com/api/health-connectors/callback
POLAR_AUTH_URL=https://flow.polar.com/oauth2/authorization
POLAR_TOKEN_URL=https://polarremote.com/v2/oauth2/token

# Garmin Health OAuth1a-style credentials
GARMIN_CONSUMER_KEY=your_garmin_consumer_key
GARMIN_CONSUMER_SECRET=your_garmin_consumer_secret
GARMIN_REDIRECT_URI=https://your-domain.com/api/health-connectors/callback
GARMIN_AUTH_URL=https://connectapi.garmin.com/oauth-service/oauth/request_token
GARMIN_AUTHORIZE_URL=https://connect.garmin.com/oauthConfirm
GARMIN_TOKEN_URL=https://connectapi.garmin.com/oauth-service/oauth/access_token

# =============================================================================
# HEALTH CONNECTORS - SMART ON FHIR (Optional)
# =============================================================================
SMART_EPIC_CLIENT_ID=your_epic_client_id
SMART_EPIC_REDIRECT_URI=https://your-domain.com/api/health-connectors/callback
SMART_EPIC_AUTH_URL=your_epic_authorization_url
SMART_EPIC_TOKEN_URL=your_epic_token_url
SMART_EPIC_FHIR_BASE_URL=your_epic_fhir_base_url

SMART_CERNER_CLIENT_ID=your_cerner_client_id
SMART_CERNER_REDIRECT_URI=https://your-domain.com/api/health-connectors/callback
SMART_CERNER_AUTH_URL=your_cerner_authorization_url
SMART_CERNER_TOKEN_URL=your_cerner_token_url
SMART_CERNER_FHIR_BASE_URL=your_cerner_fhir_base_url

SMART_ATHENA_CLIENT_ID=your_athena_client_id
SMART_ATHENA_REDIRECT_URI=https://your-domain.com/api/health-connectors/callback
SMART_ATHENA_AUTH_URL=your_athena_authorization_url
SMART_ATHENA_TOKEN_URL=your_athena_token_url
SMART_ATHENA_FHIR_BASE_URL=your_athena_fhir_base_url

# =============================================================================
# HEALTH CONNECTORS - AGGREGATOR PATH (Optional)
# =============================================================================
AGG_1UPHEALTH_CLIENT_ID=your_1uphealth_client_id
AGG_1UPHEALTH_CLIENT_SECRET=your_1uphealth_client_secret
AGG_1UPHEALTH_REDIRECT_URI=https://your-domain.com/api/health-connectors/callback
AGG_1UPHEALTH_AUTH_URL=your_1uphealth_authorization_url
AGG_1UPHEALTH_TOKEN_URL=your_1uphealth_token_url
