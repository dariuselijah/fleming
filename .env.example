AGG_PARTICLE_FHIR_BASE_URL=your_particle_fhir_base_url

# =============================================================================
# COMMUNICATIONS PLATFORM (WhatsApp inbox + optional voice backend)
# =============================================================================
# Apply DB migrations (required for threads, channels, messages, voice metadata):
#   supabase/migrations/20260407120000_comms_platform.sql
#   supabase/migrations/20260408120000_comms_patient_lookup_flow.sql
#   supabase/migrations/20260408140000_comms_voice_patient_profile.sql
#   supabase/migrations/20260408200000_comms_embedded_signup_pending_waba.sql
#   supabase/migrations/20260409120000_lab_partner_connections.sql
#   Supabase Dashboard → SQL Editor → paste & run, OR: supabase link && supabase db push
#
# Twilio — WhatsApp + number provisioning (required for Admin → Channels / Inbox)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Public https origin only, no path (e.g. https://your-app.vercel.app). Must match the URL Twilio POSTs to
# or signature checks on /api/comms/whatsapp/webhook and /status will fail. Provisioning + "Sync webhooks"
# in Admin → Channels set SMS + status + voice URLs on the purchased number via Twilio API automatically.
TWILIO_WEBHOOK_BASE_URL=https://your-domain.com
# Optional JSON map of template name → Twilio Content SID (from Content Template Builder after Meta approval).
# When set, sendTemplateMessage uses Messages API contentSid + contentVariables (business-initiated compliant).
# Example: {"appointment_reminder_24h":"HXxxxx","appointment_reminder_1h":"HXyyyy","post_visit_followup":"HXzzzz"}
# Per-practice overrides: store approved rows in whatsapp_templates (template_name + template_sid).
TWILIO_WHATSAPP_CONTENT_SIDS_JSON=
#
# Meta Embedded Signup (Twilio WhatsApp Tech Provider) — recommended for production
# Flow: buy/link number → Admin shows "Continue with Meta" → practice creates/selects WABA → Senders API + waba_id.
# Set false only for local dev without a Meta app, or while using Twilio Console-only sender registration.
# DB: apply migration supabase/migrations/20260408200000_comms_embedded_signup_pending_waba.sql (status pending_waba).
#
# Meta / Twilio checklist (once per Fleming deployment):
# 1) Twilio: enroll in WhatsApp Tech Provider program; accept Partner Solution on your Meta app; note Partner Solution ID.
# 2) Meta Developers: App → Facebook Login for Business → Configurations → create "WhatsApp Embedded Signup" → Configuration ID.
# 3) Meta: add Valid OAuth Redirect URIs = your app origin (e.g. https://app.example.com/) and localhost for dev tunnels.
# 4) Fill NEXT_PUBLIC_* below; rebuild so client embeds them.
# 5) TWILIO_WHATSAPP_USE_EMBEDDED_SIGNUP=true and restart.
#
TWILIO_WHATSAPP_USE_EMBEDDED_SIGNUP=true
# Client (NEXT_PUBLIC_*) — required when Embedded Signup is true (baked in at build time)
NEXT_PUBLIC_META_APP_ID=
# Facebook Login for Business → Configurations → WhatsApp Embedded Signup → Configuration ID
NEXT_PUBLIC_META_WHATSAPP_CONFIG_ID=
# Twilio Partner Solution ID (Meta app → Twilio partner request, or Twilio Console / docs)
NEXT_PUBLIC_TWILIO_PARTNER_SOLUTION_ID=

# Lab partner integrations (Admin → Inbox → Lancet / Ampath / PathCare)
# Resend: verify domain + create API key. From-address must be a verified sender.
# RECIPIENT: per-lab inbox if known; else LAB_INTEGRATIONS_OPS_EMAIL (Fleming ops forwards to the lab).
RESEND_API_KEY=
LAB_INTEGRATIONS_FROM_EMAIL=integrations@your-verified-domain.com
LAB_INTEGRATIONS_OPS_EMAIL=ops@your-domain.com
# Optional: route outreach directly to each lab’s integrations desk
LAB_OUTREACH_LANCET_EMAIL=
LAB_OUTREACH_AMPATH_EMAIL=
LAB_OUTREACH_PATHCARE_EMAIL=

# Vapi — voice inbound (assistant-request / tools) + outbound calls (check-in & follow-up crons)
# Dashboard: https://dashboard.vapi.ai — create API key, default assistant template, phone number import.
# Clone-on-provision (Admin → Channels) sets server URL to ${TWILIO_WEBHOOK_BASE_URL}/api/comms/voice/webhook
# Server-side REST auth (Bearer). Same value as Vapi “Private API key” if the UI only shows private/public.
VAPI_API_KEY=
# Optional alias — used if VAPI_API_KEY is unset
# VAPI_PRIVATE_KEY=
# Not used by this app (client / other products only)
# VAPI_PUBLIC_KEY=
VAPI_DEFAULT_ASSISTANT_ID=
# HMAC secret for x-vapi-signature on POST /api/comms/voice/webhook (optional but recommended in production)
VAPI_SERVER_SECRET=
# Vapi “Phone Number” resource ID used for outbound API calls (check-in / follow-up); same org as API key
VAPI_PHONE_NUMBER_ID=

# Comms agent (WhatsApp auto-reply)
COMMS_AGENT_MODEL=gpt-4o-mini
COMMS_AGENT_TEMPERATURE=0.3

# =============================================================================
# MEDIKREDIT (South African medical scheme switch) — server-only credentials
# =============================================================================
# HTTPS SOAP endpoint (default test/prod port often :4436). Never expose username/password to the browser.
MEDIKREDIT_API_URL=https://services.medikredit.co.za:4436
MEDIKREDIT_USERNAME=
MEDIKREDIT_PASSWORD=
# Set to 1 in development to skip the live switch and return canned XML (parsers still run).
MEDIKREDIT_DRY_RUN=0
# DB: supabase/migrations/20260409180000_medikredit_integration.sql — medikredit_providers, eligibility_checks, practice_claims
# API routes: /api/clinical/medikredit/eligibility | family | claim | reversal, /api/clinical/medical-coding-agents

# =============================================================================
# DEPLOYMENT & ENVIRONMENT
# =============================================================================
# Node environment (development/production)
NODE_ENV=development

# Production URL for Vercel deployment
# NEXT_PUBLIC_VERCEL_URL=your_production_url

# Official deployment flag
# FLEMING_OFFICIAL=true

# =============================================================================
# DEVELOPMENT & DEBUGGING
# =============================================================================
# Enable bundle analyzer
# ANALYZE=true

# =============================================================================
# NOTES
# =============================================================================
# - All API keys are optional but required for their respective models to work
# - CSRF_SECRET and ENCRYPTION_KEY are required for security features
# - Supabase configuration is required for authentication and data storage
# - OLLAMA_BASE_URL is only needed if you want to use local AI models
# - EXA_API_KEY powers explicit tool-based web search
# - ENABLE_WEB_SEARCH_TOOL controls server-side web search tool availability
# - ENABLE_LANGGRAPH_HARNESS enables LangGraph-based clinical orchestration
# - ENABLE_LANGCHAIN_SUPERVISOR enables hybrid LangChain supervisor orchestration
# - ENABLE_COGNITIVE_ORCHESTRATION_FULL enables advanced cognitive metadata and policy handling
# - ENABLE_CONNECTOR_REGISTRY enables extended connector tools shown in Connector gallery
# - Azure Document Intelligence keys enable OCR for image-heavy slides and notes
# - ENABLE_DOCLING_UPLOAD_PARSER defaults on; Edge Function docling-parse + optional Python runtime (DOC_RUNTIME_URL)
# - DOCLING_USE_SUPABASE_EDGE toggles automatic Supabase Edge Function URL fallback when DOCLING_SERVICE_URL is unset
# - DOCLING_SERVICE_URL overrides auto URL; otherwise uses Supabase /functions/v1/docling-parse
# - DOCLING_TIMEOUT_MS caps parsing latency before falling back to built-in extraction
# - DOCLING_MAX_FIGURES_PER_UNIT limits visual payload fan-out per source unit
# - UPLOAD_READY_GATE_MAX_WAIT_MS controls how long chat waits for selected uploads to be indexed before grounded retrieval
# - UPLOAD_READY_GATE_POLL_MS controls polling interval for upload readiness updates
# - ENABLE_STRICT_CITATION_CONTRACT strips unresolved citation placeholders before display/save
# - ENABLE_CHAT_ACTIVITY_TIMELINE_V2 toggles the unified chat activity timeline UI
# - NEXT_PUBLIC_ENABLE_CHART_DRILLDOWN_SUBLOOP enables clickable chart point explanations in chat
# - NEXT_PUBLIC_SUPABASE_STORAGE_OBJECT_LIMIT_MB should match your Supabase storage object limit
# - Native connectors (Apple HealthKit, Android Health Connect, Samsung Health) are marked as "coming soon" in UI
# - SMART on FHIR and aggregator endpoints require provider-specific onboarding and production credentials
# - Set NODE_ENV=production for production deployments
